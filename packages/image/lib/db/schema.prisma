datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  images    Image[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Image {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalKey    String
  optimizedKey   String?
  thumbnailKey   String?
  mimeType       String
  extension      String
  width          Int?
  height         Int?
  originalSize   Int
  optimizedSize  Int?
  status         ImageStatus     @default(CREATED)
  jobs           ProcessingJob[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ProcessingJob {
  id           String    @id @default(uuid())
  imageId      String
  image        Image     @relation(fields: [imageId], references: [id], onDelete: Cascade)
  status       JobStatus @default(PENDING)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?
}

enum ImageStatus {
  CREATED
  UPLOADED
  PROCESSING
  OPTIMIZED
  READY
  FAILED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

